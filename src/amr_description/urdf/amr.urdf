<?xml version="1.0"?>
<robot name="amr">

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.35 0.28 0.15"/></geometry>
      <material name="gray"><color rgba="0.4 0.4 0.4 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.35 0.28 0.15"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.155"/>
  </joint>

  <link name="left_wheel">
    <visual><origin rpy="1.5708 0 0" xyz="0 0 0"/><geometry><cylinder radius="0.09" length="0.03"/></geometry></visual>
    <collision><origin rpy="1.5708 0 0" xyz="0 0 0"/><geometry><cylinder radius="0.09" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>

  <link name="right_wheel">
    <visual><origin rpy="1.5708 0 0" xyz="0 0 0"/><geometry><cylinder radius="0.09" length="0.03"/></geometry></visual>
    <collision><origin rpy="1.5708 0 0" xyz="0 0 0"/><geometry><cylinder radius="0.09" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_wheel"/>
    <origin xyz="0 0.14 -0.065"/><axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_wheel"/>
    <origin xyz="0 -0.14 -0.065"/><axis xyz="0 1 0"/>
  </joint>

  <link name="front_left_caster">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
    <visual>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.005" length="0.07"/></geometry>
    </visual>
    <collision><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/><child link="front_left_caster"/>
    <origin xyz="0.145 0.105 -0.145"/>
  </joint>

  <link name="front_right_caster">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
    <visual>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.005" length="0.07"/></geometry>
    </visual>
    <collision><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/><child link="front_right_caster"/>
    <origin xyz="0.145 -0.105 -0.145"/>
  </joint>

  <link name="rear_left_caster">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
    <visual>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.005" length="0.07"/></geometry>
    </visual>
    <collision><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="rear_left_caster_joint" type="fixed">
    <parent link="base_link"/><child link="rear_left_caster"/>
    <origin xyz="-0.145 0.105 -0.145"/>
  </joint>

  <link name="rear_right_caster">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
    <visual>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.005" length="0.07"/></geometry>
    </visual>
    <collision><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="rear_right_caster_joint" type="fixed">
    <parent link="base_link"/><child link="rear_right_caster"/>
    <origin xyz="-0.145 -0.105 -0.145"/>
  </joint>

  <ros2_control name="DraxSystem" type="system">

    <hardware>

      <plugin>drax_hardware/DraxHardware</plugin>

      <param name="can_interface">can0</param>

      <param name="left_node_id">1</param>

      <param name="right_node_id">2</param>

      <param name="encoder_resolution">4096</param>

      <param name="feedback_resolution">4096</param>

      <param name="wheel_radius">0.09</param>

      <param name="left_invert">false</param>

      <param name="right_invert">true</param>

      <param name="fix_din3">true</param>

      <param name="sdo_timeout_ms">20</param>

      <param name="sdo_retries">3</param>

      <param name="diagnostics_period_sec">1.0</param>

      <param name="diagnostic_temperature_index">0</param>

      <param name="diagnostic_temperature_subindex">0</param>

      <param name="diagnostic_temperature_scale">1.0</param>

      <param name="diagnostic_voltage_index">0</param>

      <param name="diagnostic_voltage_subindex">0</param>

      <param name="diagnostic_voltage_scale">1.0</param>

    </hardware>

    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

</robot>
